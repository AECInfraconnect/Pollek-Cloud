{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.pollek.cloud/bundle-provenance.schema.json",
  "title": "Pollek Bundle Provenance (SLSA-style)",
  "description": "SLSA-style build provenance carried inside the signed policy-bundle manifest. Cloud-Phase-1 emits Build L2 (provenance present, signed with the bundle, builder id + source/commit + materials); the require_slsa_level in trust-policy tightens to L3 once the build path is hermetic.",
  "type": "object",
  "required": ["schema_version", "slsa_level", "build_type", "builder", "invocation", "materials"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "pollek.trust.bundle-provenance.v1"
    },
    "slsa_level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4,
      "description": "Claimed SLSA Build level. Cloud-Phase-1 emits 2; the DEK gate accepts >=2 and tightens to >=3 later."
    },
    "build_type": {
      "type": "string",
      "minLength": 1,
      "description": "URI-like identifier of the build process that produced the bundle."
    },
    "builder": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1, "description": "Stable identity of the builder, distinct from the release signer." },
        "version": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "invocation": {
      "type": "object",
      "required": ["config_source"],
      "additionalProperties": true,
      "properties": {
        "config_source": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "uri": { "type": "string" },
            "digest": { "type": "object", "additionalProperties": { "type": "string" } },
            "entry_point": { "type": "string" }
          }
        },
        "parameters": { "type": "object", "additionalProperties": true },
        "environment": { "type": "object", "additionalProperties": true }
      }
    },
    "materials": {
      "type": "array",
      "minItems": 1,
      "description": "Inputs consumed by the build (source, policies, data). Each carries a digest so tampering breaks the signed manifest.",
      "items": {
        "type": "object",
        "required": ["uri", "digest"],
        "additionalProperties": true,
        "properties": {
          "uri": { "type": "string", "minLength": 1 },
          "digest": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "properties": { "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" } }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "build_started_on": { "type": "string", "format": "date-time" },
        "build_finished_on": { "type": "string", "format": "date-time" },
        "reproducible": { "type": "boolean" },
        "completeness": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        }
      }
    }
  }
}
