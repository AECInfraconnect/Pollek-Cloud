POLLEK_CLOUD_DEV_HOST=127.0.0.1
POLLEK_CLOUD_DEV_PORT=8790
POLLEK_CLOUD_PUBLIC_URL=http://127.0.0.1:8790
DATABASE_URL=postgres://pollek:pollek@127.0.0.1:5432/pollek_cloud
KEYCLOAK_BASE_URL=http://127.0.0.1:8080
KEYCLOAK_REALM=pollek
KEYCLOAK_CLIENT_ID=pollek-cloud-console
OIDC_ISSUER=http://127.0.0.1:8080/realms/pollek
# Cloud Keycloak bearer verification on DEK-facing boundaries: off | monitor | enforce.
# Default off keeps current behavior; JWKS URL defaults to <issuer>/protocol/openid-connect/certs.
POLLEK_KEYCLOAK_JWT_MODE=off
KEYCLOAK_EXPECTED_AUDIENCE=pollek-cloud-api
KEYCLOAK_TENANT_CLAIM=tenant_id
# Human (console/admin) boundary session enforcement: off | monitor | enforce.
# Machine/DEK-facing boundaries use the Keycloak JWT gate above; public boundaries stay open.
# Enabling enforce requires the console to send its session token on every API call.
POLLEK_SESSION_MODE=off
COSMIAN_KMS_URL=http://127.0.0.1:9998
COSMIAN_KMS_KEY_ID=local-dev-pollek-signing-key
POLLEK_CLOUD_MAX_JSON_BODY_BYTES=1048576
POLLEK_CLOUD_RATE_WINDOW_MS=60000
POLLEK_CLOUD_RATE_MAX=900
POLLEK_CLOUD_DEFAULT_API_PAGE_LIMIT=1000
POLLEK_CLOUD_MAX_API_PAGE_LIMIT=5000
POLLEK_CLOUD_MAX_AUDIT_PAYLOAD_BYTES=32768
