{
  "schema_version": "pollek-cloud-contract-discovery.v1",
  "contract_version": "2026.06.29",
  "cloud_version": "0.1.0-dev",
  "minimum_local_enforcement_kit": "1.0.0-beta.1",
  "source_compatibility_target": "1.0.0-beta.10",
  "supported": ["1.0"],
  "preferred": "1.0",
  "supported_transports": ["https", "mtls", "sse", "otlp", "http-loopback-dev"],
  "schemas": {
    "openapi": "/contracts/openapi.json",
    "events": "/contracts/events.schema.json",
    "bundle_manifest": "/contracts/bundle-manifest.schema.json",
    "telemetry_envelope": "/contracts/telemetry-envelope.schema.json",
    "lcp_usage_ledger": "/contracts/lcp-usage-ledger.schema.json"
  },
  "interfaces": {
    "pollek.cloud.enrollment": {
      "direction": "local_to_cloud",
      "requires_oauth": true,
      "requires_spiffe": false,
      "paths": ["/oauth/device_authorization", "/oauth/token", "/enroll"]
    },
    "pollek.cloud.telemetry": {
      "direction": "local_to_cloud",
      "requires_oauth": true,
      "requires_spiffe": true,
      "paths": [
        "/v1/telemetry/batches",
        "/v1/telemetry/envelopes",
        "/v1/telemetry/events",
        "/v1/telemetry/decision-logs",
        "/v1/telemetry/security-events",
        "/v1/telemetry/traces",
        "/v1/telemetry/ebpf-events",
        "/v1/metrics",
        "/v1/telemetry/runtime-metrics",
        "/v1/telemetry/observations",
        "/v1/telemetry/resources",
        "/v1/telemetry/tools",
        "/v1/telemetry/identities",
        "/v1/telemetry/enforcement-status",
        "/v1/tenants/{tenant_id}/telemetry/events",
        "/v1/tenants/{tenant_id}/telemetry/observations",
        "/v1/tenants/{tenant_id}/telemetry/resources",
        "/v1/tenants/{tenant_id}/telemetry/tools",
        "/v1/tenants/{tenant_id}/telemetry/identities",
        "/v1/tenants/{tenant_id}/telemetry/guard-events",
        "/v1/tenants/{tenant_id}/browser-extension/events",
        "/v1/tenants/{tenant_id}/browser-extension/status",
        "/api/lcp/usage-ledgers",
        "/v1/tenants/{tenant_id}/lcp/usage-ledgers"
      ],
      "controls": ["secret_redaction", "schema_version_validation", "tenant_device_headers", "sender_constrained_token_planned", "lcp_usage_ledger_validation"]
    },
    "pollek.cloud.local_entities": {
      "direction": "local_to_cloud",
      "requires_oauth": true,
      "requires_spiffe": true,
      "tenant_scoped": true,
      "paths": [
        "/api/entities",
        "/api/entities/health",
        "/api/entities/dedupe",
        "/api/entities/ingest",
        "/api/entities/sync",
        "/api/entities/watch",
        "/api/lcp/change-batches",
        "/api/contract-hub/connection-updates",
        "/v1/tenants/{tenant_id}/registry/sync",
        "/v1/tenants/{tenant_id}/registry/agents",
        "/v1/tenants/{tenant_id}/registry/entities",
        "/v1/tenants/{tenant_id}/registry/relationships",
        "/v1/tenants/{tenant_id}/registry/resources",
        "/v1/tenants/{tenant_id}/registry/tools",
        "/v1/tenants/{tenant_id}/discovery/candidates",
        "/v1/tenants/{tenant_id}/discovery/entities",
        "/v1/tenants/{tenant_id}/capability-snapshot",
        "/v1/tenants/{tenant_id}/devices/{device_id}/capability-snapshot-v2",
        "/v1/tenants/{tenant_id}/lcp/change-batches"
      ],
      "entity_types": ["registered_agent", "found_agent", "policy", "enforcement", "observability"],
      "sync_strategy": {
        "primary": "lcp_outbox_delta_push",
        "fallback": "cloud_snapshot_reconcile",
        "ack_cursor_required": true,
        "idempotency": ["event_id", "sequence", "content_hash"]
      }
    },
    "pollek.cloud.contract_artifacts": {
      "direction": "local_to_cloud",
      "requires_oauth": false,
      "requires_spiffe": false,
      "paths": ["/.well-known/pollek-contract", "/contracts/openapi.json", "/contracts/events.schema.json", "/contracts/bundle-manifest.schema.json", "/contracts/telemetry-envelope.schema.json", "/contracts/lcp-usage-ledger.schema.json", "/api/contract-hub/drift"],
      "purpose": "Contract Hub publishes machine-readable cloud protocol artifacts and drift status for Local Pollek compatibility checks."
    },
    "pollek.cloud.policy_bundle": {
      "direction": "cloud_to_local",
      "hot_reload": true,
      "requires_oauth": true,
      "requires_spiffe": true,
      "paths": ["/v1/tenants/{tenant_id}/bundles/latest", "/v1/tenants/{tenant_id}/devices/{device_id}/bundles/latest", "/v1/policy-bundles/{bundle_id}/manifest", "/v1/policy-bundles/{bundle_id}/artifact"],
      "controls": ["signed_manifest", "content_addressed_artifact", "immutable_cache", "artifact_hash"]
    },
    "pollek.cloud.policy_bundle_signing": {
      "direction": "cloud_admin",
      "requires_oauth": true,
      "requires_spiffe": false,
      "tenant_scoped": true,
      "human_approval_required": true,
      "paths": ["/api/policy-bundles/{bundle_id}/sign", "/api/policy-bundles/{bundle_id}/verify"],
      "controls": ["approval_record_required", "ed25519_signature", "payload_hash", "public_key_pinning", "audit_event", "task_record"]
    },
    "pollek.cloud.policy_authoring": {
      "direction": "cloud_admin",
      "requires_oauth": true,
      "requires_spiffe": false,
      "human_approval_required": true,
      "paths": ["/api/policy/providers", "/api/policy/assist", "/api/policy/drafts", "/api/policy/drafts/{draft_id}/simulate", "/api/policy/drafts/{draft_id}/approve", "/api/policy/sandbox"],
      "controls": ["secret_redaction", "citation_manifest", "policy_test_fixtures", "human_approval_required"]
    },
    "pollek.cloud.enterprise_compliance": {
      "direction": "cloud_admin_to_local_bundle",
      "requires_oauth": true,
      "requires_spiffe": true,
      "enterprise_only": true,
      "entitlement": "enterprise.compliance_policy_bundles",
      "local_catalog_visible": false,
      "paths": ["/api/compliance/policy-bundles", "/api/compliance/policy-bundles/simulate", "/api/compliance/policy-bundles/deploy", "/api/compliance/score", "/v1/tenants/{tenant_id}/bundles/latest", "/v1/tenants/{tenant_id}/devices/{device_id}/bundles/latest", "/v1/policy-bundles/{bundle_id}/manifest"]
    },
    "pollek.cloud.breakglass": {
      "direction": "cloud_admin",
      "requires_oauth": true,
      "requires_spiffe": false,
      "enterprise_only": true,
      "paths": ["/api/breakglass", "/api/breakglass/{request_id}/approve", "/api/breakglass/{request_id}/reject", "/api/breakglass/{request_id}/close"],
      "constraints": ["explicit", "time_bound", "audited", "no_kernel_deny_bypass_by_default"]
    },
    "pollek.cloud.adapter_catalog": {
      "direction": "cloud_admin",
      "requires_oauth": true,
      "requires_spiffe": false,
      "paths": ["/api/adapters/catalog"],
      "source": "curated-cloud-catalog"
    },
    "pollek.cloud.integrations": {
      "direction": "cloud_to_siem",
      "requires_oauth": true,
      "requires_spiffe": false,
      "paths": ["/api/integrations/summary", "/api/integrations/{integration_id}/test", "/api/evidence/exports"]
    },
    "pollek.cloud.trust_scope": {
      "direction": "cloud_admin",
      "requires_oauth": true,
      "requires_spiffe": false,
      "tenant_scoped": true,
      "paths": ["/api/trust/scopes", "/api/services/endpoints", "/api/contract-hub/connection-updates"],
      "service_types": ["spire", "spiffe", "opa", "cedar", "openfga", "ner", "wasm"]
    },
    "pollek.cloud.authorization": {
      "direction": "cloud_admin",
      "requires_oauth": true,
      "requires_spiffe": false,
      "tenant_scoped": true,
      "paths": ["/api/authz/model", "/api/authz/tuples", "/api/authz/check", "/api/authz/decisions"],
      "engines": ["rbac", "rebac", "cedar", "openfga"],
      "controls": ["explicit_tenant_context", "default_deny", "tuple_storage", "cedar_policy_guard", "audit_event"]
    },
    "pollek.cloud.identity": {
      "direction": "cloud_console",
      "requires_oauth": true,
      "requires_spiffe": false,
      "tenant_scoped": true,
      "paths": ["/v1/signup/tenant", "/v1/invitations/accept", "/v1/auth/login", "/v1/auth/callback", "/v1/auth/logout", "/v1/auth/session", "/v1/tenants/{tenant_id}/invitations", "/v1/tenants/{tenant_id}/members", "/v1/tenants/{tenant_id}/members/{account_id}", "/v1/tenants/{tenant_id}/members/{account_id}/roles", "/v1/tenants/{tenant_id}/authz/tuples", "/v1/authz/check", "/v1/tenants/{tenant_id}/identity-providers", "/scim/v2/Users", "/scim/v2/Groups"],
      "providers": ["keycloak_oidc", "byo_oidc", "saml_bridge_planned", "scim"],
      "controls": ["authorization_code_pkce", "issuer_validation", "session_token_hash", "invitation_token_hash", "explicit_tenant_context", "audit_event", "scim_tenant_isolation"]
    },
    "pollek.cloud.billing": {
      "direction": "cloud_admin",
      "requires_oauth": true,
      "requires_spiffe": false,
      "tenant_scoped": true,
      "paths": ["/v1/tenants/{tenant_id}/billing/subscription", "/v1/tenants/{tenant_id}/billing/usage", "/v1/tenants/{tenant_id}/billing/invoices", "/v1/tenants/{tenant_id}/billing/payment-methods", "/v1/tenants/{tenant_id}/billing/license/issue", "/v1/billing/webhooks/{provider}", "/api/lcp/usage-ledgers", "/v1/tenants/{tenant_id}/lcp/usage-ledgers"],
      "meters": ["console_seats", "local_control_planes", "managed_devices", "telemetry_events", "ai_model_tokens", "ai_model_credits", "ai_model_estimated_cost_cents"],
      "controls": ["seat_device_lcp_metering", "lcp_reported_agent_usage_ledger", "credit_pool_allocation", "cloud_validation_reconciliation", "payment_token_hash", "webhook_idempotency", "offline_license", "audit_event", "task_record"]
    },
    "pollek.cloud.kms": {
      "direction": "cloud_admin",
      "requires_oauth": true,
      "requires_spiffe": false,
      "tenant_scoped": true,
      "paths": ["/v1/kms/health"],
      "providers": ["openbao", "cosmian_kms", "aws_kms", "azure_key_vault", "gcp_cloud_kms"],
      "controls": ["signing_key_health", "key_rotation_status", "no_plaintext_private_key_export"]
    },
    "pollek.cloud.connection_update": {
      "direction": "cloud_to_local",
      "requires_oauth": true,
      "requires_spiffe": true,
      "tenant_scoped": true,
      "paths": ["/.well-known/pollek-contract", "/api/contract-hub/connection-updates", "/api/lcp/config/dispatch", "/api/lcp/hot-reload/dispatch", "/api/hot-reload/events", "/api/events", "/api/events/replay", "/api/hot-reload/stream"],
      "purpose": "Contract Hub mediates endpoint, trust scope, registry sync, telemetry, bundle, enterprise entitlement, and hot reload connection updates for many Local Pollek instances."
    },
    "pollek.cloud.secure_control_channel": {
      "direction": "bidirectional",
      "requires_oauth": true,
      "requires_spiffe": true,
      "requires_mtls": true,
      "paths": ["/api/entities/watch", "/api/lcp/change-batches", "/api/lcp/config/dispatch", "/api/lcp/hot-reload/dispatch", "/v1/tenants/{tenant_id}/lcp/change-batches"],
      "controls": ["signed-control-envelope", "nonce", "expiry", "payload_hash", "allowlisted_paths", "audit_event", "least_privilege_scope", "secret_redaction", "ack_cursor", "idempotency_key", "replay_window"]
    }
  },
  "features": {
    "hot_reload": true,
    "signed_bundles": true,
    "policy_bundle_signing_verification": true,
    "content_addressed_bundle_artifacts": true,
    "spiffe_mtls": true,
    "oauth_device_flow": true,
    "telemetry_otlp": true,
    "lcp_telemetry_endpoint_family": true,
    "lcp_contract_compatibility_2026_06_30": true,
    "ai_policy_editor": true,
    "ai_policy_provider_redaction_citations": true,
    "local_entity_inventory": true,
    "tenant_trust_scopes": true,
    "authorization_rbac_rebac_cedar_openfga": true,
    "spire_server_scope": true,
    "contract_hub_connection_updates": true,
    "wasm_hot_reload_registry": true,
    "staged_rollouts": true,
    "adapter_catalog": true,
    "entity_health": true,
    "entity_dedupe": true,
    "policy_sandbox": true,
    "breakglass": true,
    "enterprise_compliance_policy_bundles": true,
    "openapi_artifact": true,
    "contract_drift_guard": true,
    "sse_event_stream": true,
    "durable_event_stream_replay": true,
    "near_real_time_lcp_watch": true,
    "hybrid_lcp_delta_push": true,
    "lcp_ai_usage_ledger": true,
    "lcp_change_batch_ack_cursor": true,
    "secure_cloud_to_local_dispatch": true,
    "signed_control_envelopes": true,
    "dev_loopback_protocol_test": true,
    "saas_signup": true,
    "keycloak_oidc": true,
    "byo_idp_federation": true,
    "scim_provisioning": true,
    "tenant_member_management": true,
    "session_token_hash_at_rest": true,
    "metered_billing_seat_device": true,
    "offline_license": true,
    "kms_abstraction": true,
    "billing_webhook_idempotency": true
  }
}
